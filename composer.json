{
    "name": "presentation-server/websockets-demo",
    "description": "Socket Conveyor presentation server for PHPTek 2026 WebSockets talk",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-openswoole": ">=22.0",
        "kanata-php/socket-conveyor": "^2.4",
        "openswoole/ide-helper": "^26.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "phpro/grumphp": false
        }
    }
}
